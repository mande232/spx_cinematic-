# Admin PIN for /admin dashboard and protected API routes.
# Change this before any public deployment.
ADMIN_PIN=1234

# Public site URL baked into QR codes (must be absolute, no trailing slash).
# Required when the LED wall is opened via localhost/LAN IP but phones should
# open the deployed site. On Vercel, set this to your production URL and redeploy
# (Vite inlines this at build time).
# VITE_PUBLIC_SITE_URL=https://spx-cinematic.vercel.app

# Optional: remove.bg API key for real background removal in production.
# REMOVE_BG_API_KEY=

# Optional: webhook URL for CRM visitor export from admin dashboard.
# CRM_WEBHOOK_URL=https://hooks.example.com/spx-visitors

# Required on Vercel (or any serverless host): shared store so all function
# instances see the same session + pairing token. Create an Upstash Redis
# database (Vercel Marketplace) and set either pair of variables:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# (Vercel KV naming also works)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
